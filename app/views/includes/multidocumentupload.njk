{% macro multiDocumentUpload(params = {}) %}

<span class="govuk-caption-l">{{ params.caption or "Appeal 12345678" }}</span>

<h1 class="govuk-heading-l">{{ params.heading or "Upload cross-team correspondence" }}</h1>

<p>
  Each file must be a PDF, DOC, DOCX, PPT, PPTX, XLS, XLSX, MSG, JPG, JPEG, MPEG, MP3, MP4, MOV, PNG, TIF or TIFF
  and smaller than 250MB.
</p>

<p>The total size of your uploaded files must be smaller than 1GB.</p>

<div class="moj-multi-file-upload" 
     data-module="multi-file-upload"
     data-upload-url="{{ params.uploadUrl }}">
  <!-- Dashed box upload area -->
  <div class="moj-multi-file-upload__upload"
       style="border: 2px dashed #b1b4b6; padding: 60px 16px; display: flex; align-items: center; background-color: #ffffff; margin-bottom: 30px;">
    <div class="govuk-form-group" style="margin-bottom: 0; display: flex; align-items: center;">
      <label class="govuk-button govuk-button--secondary" for="documents" style="margin-bottom: 0; cursor: pointer;">
        Choose files
      </label>
      <p class="govuk-body" style="margin: 0; margin-left: 10px;">or drop files</p>
      <input
        class="govuk-file-upload moj-multi-file-upload__input"
        id="documents"
        name="documents"
        type="file"
        multiple
        style="position: absolute; left: -9999px;">
    </div>
  </div>
  <!-- End dashed box upload area -->

  <!-- THIS IS REQUIRED: placeholder for progress bars and file list -->
       <div class="moj-multi-file__uploaded-files"></div>

</div>

{% endmacro %}