{% set currentSection = currentSection or "overview" %}
{% set inferredVersion = urlVersion or "v1" %}
{% if location and '/v' in location %}
  {% set inferredVersion = "v" + location.split('/v')[1].split('/')[0] %}
{% endif %}
{% set configuredVersions = workflowNavVersions or {} %}
{% set overviewVersion = inferredVersion %}
{% if overviewVersion != 'v1' and overviewVersion != 'v2' %}
  {% set overviewVersion = 'v2' %}
{% endif %}
{% if configuredVersions.overview == 'v1' or configuredVersions.overview == 'v2' %}
  {% set overviewVersion = configuredVersions.overview %}
{% endif %}

{% set timetableVersion = inferredVersion %}
{% if timetableVersion != 'v1' %}
  {% set timetableVersion = 'v1' %}
{% endif %}
{% if configuredVersions.timetable == 'v1' %}
  {% set timetableVersion = configuredVersions.timetable %}
{% endif %}

{% set gw1Version = inferredVersion %}
{% if gw1Version != 'v1' %}
  {% set gw1Version = 'v1' %}
{% endif %}
{% if configuredVersions.gw1 == 'v1' %}
  {% set gw1Version = configuredVersions.gw1 %}
{% endif %}

{% set gw2Version = inferredVersion %}
{% if gw2Version != 'v2' and gw2Version != 'v3' %}
  {% set gw2Version = 'v3' %}
{% endif %}
{% if configuredVersions.gw2 == 'v2' or configuredVersions.gw2 == 'v3' %}
  {% set gw2Version = configuredVersions.gw2 %}
{% endif %}

{% set gw3Version = 'v2' %}
{% if configuredVersions.gw3 == 'v2' %}
  {% set gw3Version = configuredVersions.gw3 %}
{% endif %}

{% set examinationVersion = inferredVersion %}
{% if examinationVersion != 'v1' and examinationVersion != 'v2' and examinationVersion != 'v3' %}
  {% set examinationVersion = 'v3' %}
{% endif %}
{% if configuredVersions.examination == 'v1' or configuredVersions.examination == 'v2' or configuredVersions.examination == 'v3' %}
  {% set examinationVersion = configuredVersions.examination %}
{% endif %}

{% set documentsVersion = inferredVersion %}
{% if documentsVersion != 'v1' %}
  {% set documentsVersion = 'v1' %}
{% endif %}
{% if configuredVersions.documents == 'v1' %}
  {% set documentsVersion = configuredVersions.documents %}
{% endif %}

{% set updatesVersion = inferredVersion %}
{% if updatesVersion != 'v1' and updatesVersion != 'v2' %}
  {% set updatesVersion = 'v1' %}
{% endif %}
{% if configuredVersions.updates == 'v1' or configuredVersions.updates == 'v2' %}
  {% set updatesVersion = configuredVersions.updates %}
{% endif %}

{% set versions = versions or {
  overview: overviewVersion,
  timetable: timetableVersion,
  gw1: gw1Version,
  gw2: gw2Version,
  gw3: gw3Version,
  examination: examinationVersion,
  documents: documentsVersion,
  updates: updatesVersion
} %}

{% set links = {
  overview: "/projects/back-office/manage/overview/" ~ versions.overview ~ "/index-side",
  timetable: "/projects/back-office/manage/timetable/" ~ versions.timetable ~ "/timetable-side",
  gw1: "/projects/back-office/manage/GW1/" ~ versions.gw1 ~ "/gateway-1-side",
  gw2: "/projects/back-office/manage/GW2/" ~ versions.gw2 ~ "/gateway-2-side.html",
  gw3: "/projects/back-office/manage/GW3/" ~ versions.gw3 ~ "/gateway-3-side.html",
  examination: "/projects/back-office/manage/examination/" ~ versions.examination ~ "/examination-side",
  documents: "/projects/back-office/manage/documents/" ~ versions.documents ~ "/documents-side",
  updates: "/projects/back-office/manage/updates/" ~ versions.updates ~ "/updates-side.html"
} %}

<h2 id="case-workflow-nav-heading" class="govuk-visually-hidden">Case workflow navigation</h2>

<nav class="side-nav" aria-labelledby="case-workflow-nav-heading">
  <ul class="govuk-list">
    <li>
      <a href="{{ links.overview }}"{% if currentSection == 'overview' %} class="selected" aria-current="page"{% endif %}>
        Overview
      </a>
    </li>
    <li>
      <a href="{{ links.timetable }}"{% if currentSection == 'timetable' %} class="selected" aria-current="page"{% endif %}>
        Timetable
      </a>
    </li>
    <li>
      <a href="{{ links.gw1 }}"{% if currentSection == 'gw1' %} class="selected" aria-current="page"{% endif %}>
        Gateway 1
      </a>
    </li>
    <li>
      <a href="{{ links.gw2 }}"{% if currentSection == 'gw2' %} class="selected" aria-current="page"{% endif %}>
        Gateway 2
      </a>
    </li>
    <li>
      <a href="{{ links.gw3 }}"{% if currentSection == 'gw3' %} class="selected" aria-current="page"{% endif %}>
        Gateway 3
      </a>
    </li>
    <li>
      <a href="{{ links.examination }}"{% if currentSection == 'examination' %} class="selected" aria-current="page"{% endif %}>
        Examination
      </a>
    </li>
    <li>
      <a href="{{ links.documents }}"{% if currentSection == 'documents' %} class="selected" aria-current="page"{% endif %}>
        Documents
      </a>
    </li>
    <li>
      <a href="{{ links.updates }}"{% if currentSection == 'updates' %} class="selected" aria-current="page"{% endif %}>
        Case history
      </a>
    </li>
  </ul>
</nav>