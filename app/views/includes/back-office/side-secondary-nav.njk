{% set currentSection = currentSection or "overview" %}
{% set inferredVersion = urlVersion or "v1" %}
{% if location and '/v' in location %}
  {% set inferredVersion = "v" + location.split('/v')[1].split('/')[0] %}
{% endif %}
{# Define which versions exist for each section, in preference order #}
{% set cascade = {
  overview: [inferredVersion, 'v2', 'v1'],
  timetable: [inferredVersion, 'v1'],
  gw1: [inferredVersion, 'v1'],
  gw2: [inferredVersion, 'v2', 'v1'],
  gw3: [inferredVersion, 'v2', 'v1'],
  examination: [inferredVersion, 'v3', 'v2', 'v1'],
  documents: [inferredVersion, 'v1'],
  updates: [inferredVersion, 'v1']
} %}
{# Use cascade[section][0] for each link; allow override via versions param #}
{% set versions = versions or cascade %}

{% set links = {
  overview: "/projects/back-office/manage/overview/" ~ versions.overview[0] ~ "/index-side",
  timetable: "/projects/back-office/manage/timetable/" ~ versions.timetable[0] ~ "/timetable-side",
  gw1: "/projects/back-office/manage/GW1/" ~ versions.gw1[0] ~ "/gateway-1-side",
  gw2: "/projects/back-office/manage/GW2/" ~ versions.gw2[0] ~ "/gateway-2-side",
  gw3: "/projects/back-office/manage/GW3/" ~ versions.gw3[0] ~ "/gateway-3-side",
  examination: "/projects/back-office/manage/examination/" ~ versions.examination[0] ~ "/examination-side",
  documents: "/projects/back-office/manage/documents/upload/" ~ versions.documents[0] ~ "/documents-side",
  updates: "/projects/back-office/manage/updates/" ~ versions.updates[0] ~ "/updates-side.html"
} %}

<h2 id="case-workflow-nav-heading" class="govuk-visually-hidden">Case workflow navigation</h2>

<nav class="side-nav" aria-labelledby="case-workflow-nav-heading">
  <ul class="govuk-list">
    <li>
      <a href="{{ links.overview }}"{% if currentSection == 'overview' %} class="selected" aria-current="page"{% endif %}>
        Overview
      </a>
    </li>
    <li>
      <a href="{{ links.timetable }}"{% if currentSection == 'timetable' %} class="selected" aria-current="page"{% endif %}>
        Timetable
      </a>
    </li>
    <li>
      <a href="{{ links.gw1 }}"{% if currentSection == 'gw1' %} class="selected" aria-current="page"{% endif %}>
        Gateway 1
      </a>
    </li>
    <li>
      <a href="{{ links.gw2 }}"{% if currentSection == 'gw2' %} class="selected" aria-current="page"{% endif %}>
        Gateway 2
      </a>
    </li>
    <li>
      <a href="{{ links.gw3 }}"{% if currentSection == 'gw3' %} class="selected" aria-current="page"{% endif %}>
        Gateway 3
      </a>
    </li>
    <li>
      <a href="{{ links.examination }}"{% if currentSection == 'examination' %} class="selected" aria-current="page"{% endif %}>
        Examination
      </a>
    </li>
    <li>
      <a href="{{ links.documents }}"{% if currentSection == 'documents' %} class="selected" aria-current="page"{% endif %}>
        Documents
      </a>
    </li>
    <li>
      <a href="{{ links.updates }}"{% if currentSection == 'updates' %} class="selected" aria-current="page"{% endif %}>
        Updates
      </a>
    </li>
  </ul>
</nav>