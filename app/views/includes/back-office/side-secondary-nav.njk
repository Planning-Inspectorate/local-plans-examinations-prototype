{% set currentSection = currentSection or "overview" %}
{% set inferredVersion = urlVersion or "v1" %}
{% if location and '/v' in location %}
  {% set inferredVersion = "v" + location.split('/v')[1].split('/')[0] %}
{% endif %}
{% set configuredVersions = workflowNavVersions or {} %}
{% set versions = versions or {
  overview: configuredVersions.overview or inferredVersion,
  timetable: configuredVersions.timetable or inferredVersion,
  gw1: configuredVersions.gw1 or inferredVersion,
  gw2: configuredVersions.gw2 or inferredVersion,
  gw3: configuredVersions.gw3 or inferredVersion,
  examination: configuredVersions.examination or inferredVersion,
  documents: configuredVersions.documents or inferredVersion,
  updates: configuredVersions.updates or inferredVersion
} %}

{% set links = {
  overview: "/projects/back-office/manage/overview/" ~ versions.overview ~ "/index-side",
  timetable: "/projects/back-office/manage/timetable/" ~ versions.timetable ~ "/timetable-side",
  gw1: "/projects/back-office/manage/GW1/" ~ versions.gw1 ~ "/gateway-1-side",
  gw2: "/projects/back-office/manage/GW2/" ~ versions.gw2 ~ "/gateway-2-side",
  gw3: "/projects/back-office/manage/GW3/" ~ versions.gw3 ~ "/gateway-3-side",
  examination: "/projects/back-office/manage/examination/" ~ versions.examination ~ "/examination-side",
  documents: "/projects/back-office/manage/documents/" ~ versions.documents ~ "/documents-side",
  updates: "/projects/back-office/manage/updates/" ~ versions.updates ~ "/updates-side.html"
} %}

<h2 id="case-workflow-nav-heading" class="govuk-visually-hidden">Case workflow navigation</h2>

<nav class="side-nav" aria-labelledby="case-workflow-nav-heading">
  <ul class="govuk-list">
    <li>
      <a href="{{ links.overview }}"{% if currentSection == 'overview' %} class="selected" aria-current="page"{% endif %}>
        Overview
      </a>
    </li>
    <li>
      <a href="{{ links.timetable }}"{% if currentSection == 'timetable' %} class="selected" aria-current="page"{% endif %}>
        Timetable
      </a>
    </li>
    <li>
      <a href="{{ links.gw1 }}"{% if currentSection == 'gw1' %} class="selected" aria-current="page"{% endif %}>
        Gateway 1
      </a>
    </li>
    <li>
      <a href="{{ links.gw2 }}"{% if currentSection == 'gw2' %} class="selected" aria-current="page"{% endif %}>
        Gateway 2
      </a>
    </li>
    <li>
      <a href="{{ links.gw3 }}"{% if currentSection == 'gw3' %} class="selected" aria-current="page"{% endif %}>
        Gateway 3
      </a>
    </li>
    <li>
      <a href="{{ links.examination }}"{% if currentSection == 'examination' %} class="selected" aria-current="page"{% endif %}>
        Examination
      </a>
    </li>
    <li>
      <a href="{{ links.documents }}"{% if currentSection == 'documents' %} class="selected" aria-current="page"{% endif %}>
        Documents
      </a>
    </li>
    <li>
      <a href="{{ links.updates }}"{% if currentSection == 'updates' %} class="selected" aria-current="page"{% endif %}>
        Case history
      </a>
    </li>
  </ul>
</nav>