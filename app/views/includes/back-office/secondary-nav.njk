{% set currentSection = currentSection or "overview" %}
{% set inferredVersion = urlVersion or "v1" %}
{% if location and '/v' in location %}
  {% set inferredVersion = "v" + location.split('/v')[1].split('/')[0] %}
{% endif %}
{% set configuredVersions = workflowNavVersions or {} %}
{% set versions = versions or {
  overview: configuredVersions.overview or inferredVersion,
  timetable: configuredVersions.timetable or inferredVersion,
  gw1: configuredVersions.gw1 or inferredVersion,
  gw2: configuredVersions.gw2 or inferredVersion,
  gw3: configuredVersions.gw3 or inferredVersion,
  examination: configuredVersions.examination or inferredVersion,
  documents: configuredVersions.documents or inferredVersion,
  updates: configuredVersions.updates or inferredVersion
} %}
{% set links = {
  overview: "/projects/back-office/manage/overview/" ~ versions.overview ~ "/index",
  timetable: "/projects/back-office/manage/timetable/" ~ versions.timetable ~ "/timetable.html",
  gw1: "/projects/back-office/manage/GW1/" ~ versions.gw1 ~ "/gateway-1",
  gw2: "/projects/back-office/manage/GW2/" ~ versions.gw2 ~ "/gateway-2",
  gw3: "/projects/back-office/manage/GW3/" ~ versions.gw3 ~ "/gateway-3",
  examination: "/projects/back-office/manage/examination/" ~ versions.examination ~ "/examination",
  documents: "/projects/back-office/manage/documents/" ~ versions.documents ~ "/documents",
  updates: "/projects/back-office/manage/updates/" ~ versions.updates ~ "/updates.html"
} %}
<h2 id="case-workflow-nav-heading" class="govuk-visually-hidden">Case workflow navigation</h2>
<nav class="x-govuk-secondary-navigation app-secondary-nav govuk-!-margin-top-6 govuk-!-margin-bottom-6" aria-labelledby="case-workflow-nav-heading">
  <ul class="x-govuk-secondary-navigation__list">
    <li class="x-govuk-secondary-navigation__list-item{% if currentSection == 'overview' %} x-govuk-secondary-navigation__list-item--current{% endif %}">
      <a class="x-govuk-secondary-navigation__link" href="{{ links.overview }}"{% if currentSection == 'overview' %} aria-current="page"{% endif %}>Overview</a>
    </li>
    <li class="x-govuk-secondary-navigation__list-item{% if currentSection == 'timetable' %} x-govuk-secondary-navigation__list-item--current{% endif %}">
      <a class="x-govuk-secondary-navigation__link" href="{{ links.timetable }}"{% if currentSection == 'timetable' %} aria-current="page"{% endif %}>Timetable</a>
    </li>
    <li class="x-govuk-secondary-navigation__list-item{% if currentSection == 'gw1' %} x-govuk-secondary-navigation__list-item--current{% endif %}">
      <a class="x-govuk-secondary-navigation__link" href="{{ links.gw1 }}"{% if currentSection == 'gw1' %} aria-current="page"{% endif %}>Gateway 1</a>
    </li>
    <li class="x-govuk-secondary-navigation__list-item{% if currentSection == 'gw2' %} x-govuk-secondary-navigation__list-item--current{% endif %}">
      <a class="x-govuk-secondary-navigation__link" href="{{ links.gw2 }}"{% if currentSection == 'gw2' %} aria-current="page"{% endif %}>Gateway 2</a>
    </li>
    <li class="x-govuk-secondary-navigation__list-item{% if currentSection == 'gw3' %} x-govuk-secondary-navigation__list-item--current{% endif %}">
      <a class="x-govuk-secondary-navigation__link" href="{{ links.gw3 }}"{% if currentSection == 'gw3' %} aria-current="page"{% endif %}>Gateway 3</a>
    </li>
    <li class="x-govuk-secondary-navigation__list-item{% if currentSection == 'examination' %} x-govuk-secondary-navigation__list-item--current{% endif %}">
      <a class="x-govuk-secondary-navigation__link" href="{{ links.examination }}"{% if currentSection == 'examination' %} aria-current="page"{% endif %}>Examination</a>
    </li>
    <li class="x-govuk-secondary-navigation__list-item{% if currentSection == 'documents' %} x-govuk-secondary-navigation__list-item--current{% endif %}">
      <a class="x-govuk-secondary-navigation__link" href="{{ links.documents }}"{% if currentSection == 'documents' %} aria-current="page"{% endif %}>Documents</a>
    </li>
    <li class="x-govuk-secondary-navigation__list-item{% if currentSection == 'updates' %} x-govuk-secondary-navigation__list-item--current{% endif %}">
      <a class="x-govuk-secondary-navigation__link" href="{{ links.updates }}"{% if currentSection == 'updates' %} aria-current="page"{% endif %}>Updates</a>
    </li>
  </ul>
</nav>