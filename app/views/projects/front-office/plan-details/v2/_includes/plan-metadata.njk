<style>
  .app-header {
    margin-bottom: 20px;
  }

  .app-header__title {
    margin-bottom: 5px;
  }

  .app-header__tag {
    margin-bottom: 15px;
  }

  .app-details .govuk-summary-list__key,
  .app-details .govuk-summary-list__value {
    padding-top: 6px;
    padding-bottom: 6px;
  }

  .app-stage {
    display: flex;
    align-items: center;
    gap: 8px;
  }
</style>

{# Default state (important fallback) #}
{% set stageTagText = "Unknown status" %}
{% set stageTagClass = "govuk-tag--grey" %}
{% set ctaText = "" %}
{% set ctaHref = "" %}
{% set showMessage = false %}

{# State logic #}
{% if planStatus == 'ready' %}

  {% set stageTagText = "Ready to start" %}
  {% set stageTagClass = "govuk-tag--green" %}
  {% set ctaText = "Start gateway 2 submission" %}
  {% set ctaHref = "/projects/front-office/gw2/v2/application-details" %}
  {% set showMessage = false %}

{% elif planStatus == 'in-progress' %}

  {% set stageTagText = "In progress" %}
  {% set stageTagClass = "govuk-tag--blue" %}
  {% set ctaText = "Continue gateway 2 submission" %}
  {% set ctaHref = "/projects/front-office/gw2/v2/application-details" %}
  {% set showMessage = false %}

{% elif planStatus == 'with-pins' %}

  {% set stageTagText = "With PINS" %}
  {% set stageTagClass = "govuk-tag--yellow" %}
  {% set showMessage = true %}

{% endif %}

{# Current stage HTML #}
{% set currentStageHtml %}
  <div class="app-stage">
    <span>Gateway 2</span>
    <strong class="govuk-tag {{ stageTagClass }}">
      {{ stageTagText }}
    </strong>
  </div>
{% endset %}

{# Summary list #}
{{ govukSummaryList({
  classes: "app-details govuk-summary-list--no-border",
  rows: [
    {
      key: { text: "Current stage", classes: "govuk-!-width-one-half" },
      value: {
        html: currentStageHtml
      }
    },
    {
      key: { text: "Local planning authority", classes: "govuk-!-width-one-half" },
      value: { text: "Southampton City Council (lead)" }
    },
    {
      key: { text: "Linked local planning authorities", classes: "govuk-!-width-one-half" },
      value: { text: "Romsey Town Council" }
    }
  ]
}) }}


{# CTA / status message #}
{% if showMessage %}

{% else %}

  {{ govukButton({
    text: ctaText,
    href: ctaHref
  }) }}

{% endif %}