{% extends "layouts/front-office.html" %}


{% block pageTitle %}
  Portal index – {{ serviceName }}
{% endblock %}


{% block beforeContent %}
{% from "govuk/components/service-navigation/macro.njk" import govukServiceNavigation %}

{{ govukServiceNavigation({
  classes: "govuk-grid-column-full",
  navigation: [
    {
      href: "application-details",
      text: "Application details",
      active: true
    },  
    {
      href: "account-settings",
      text: "Acccount settings"
    },
    {
      href: "manage-users",
      text: "Manage users"
    },
    {
      href: "#",
      text: "This menu should be included in the header."
    }
  ]
}) }}
  {{ govukBackLink({
  text: "Back",
  href: "javascript:window.history.back()"
}) 
}}

{% endblock %}


{% block content %}
  <h1 class="govuk-heading-l">Application reference: PLAN/12345</h1>


<div class="govuk-grid-row">

    
    <div class="govuk-grid-column-one-half govuk-body">
      Local Authority: Liverpool City Council</div>
    <div class="govuk-grid-column-one-half govuk-body">
     Region: North West</div>
    </div>

    {# Size modifiers: xl, l, m #}
    <hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible">
<! -- // Main content -->
<div class="govuk-grid-row">
  <div >
    <!-- <h2 class="govuk-heading-m">Tasks</h2> -->


<div class="govuk-tabs govuk-grid-column-full">
  
<div data-module="govuk-tabs">
  <h2 class="govuk-tabs__title">
    Documents
  </h2>

  <ul class="govuk-tabs__list">
    <li class="govuk-tabs__list-item govuk-tabs__list-item--selected">
      <a class="govuk-tabs__tab" href="#documents">
        Documents
      </a>
    </li>
    
   
  </ul>
  <div class="govuk-tabs__panel" id="documents">
    <p>Upload the application files.</p>
    <h3 class="govuk-heading-m ">Procedural documents</h3>
    <p class="govuk-body">These documents describe how the local plan will be prepared and assessed.</p>
    {{ govukTaskList({
      idPrefix: "application-documents",
      items: [
        {
          title: {
            text: "Gateway 2 covering letter"
          },
          href: "document-category",
          status: {
            text: "Completed"
          }
        },
        {
          title: {
            text: "Local plan timetable"
          },
          href: "/projects/front-office/document-upload?category=Local%20plan%20timetable",
          status: {
            tag: {
              text: "Incomplete",
              classes: "govuk-tag--blue"
            }
          }
        },
        {
          title: {
            text: "Project initiation document"
          },
          hint: {
            text: "Do we need information about each document here?"
          },
          href: "#",
          status: {
            tag: {
              text: "Incomplete",
              classes: "govuk-tag--blue"
            }
          }
        },
        {
          title: {
            text: "Draft statement of compliance"
          },
          href: "#",
          status: {
            tag: {
              text: "Incomplete",
              classes: "govuk-tag--blue"
            }
          }
        },
        {
          title: {
            text: "Draft statement of soundness"
          },
          href: "#",
          status: {
            tag: {
              text: "Incomplete",
              classes: "govuk-tag--blue"
            }
          }
        }
      ]
    }) }}

    <div class="govuk-!-margin-top-4">&nbsp;</div>
    <h3 class="govuk-heading-m">Consultation documents</h3>
    <p class="govuk-body">These documents show how consultation has been carried out and what feedback was received.</p>
     {{ govukTaskList({
      idPrefix: "application-documents",
      items: [
        {
          title: {
            text: "Consultation statement"
          },
          href: "#",
          status: {
            tag: {
              text: "Incomplete",
              classes: "govuk-tag--blue"
            }
          }
        },
        {
          title: {
            text: "Consultation summary for scoping consultation"
          },
          href: "#",
          status: {
            tag: {
              text: "Incomplete",
              classes: "govuk-tag--blue"
            }
          }
        },
        {
          title: {
            text: "Consultation summary for proposed local plan content and evidence documents"
          },
          href: "#",
          status: {
            tag: {
              text: "Incomplete",
              classes: "govuk-tag--blue"
            }
          }
        }
      ]
    }) }}
    {{ govukTaskList({
      idPrefix: "application-documents",
      items: [
        {
          title: {
            text: "Notice of intention to commence local plan preparation"
          },
          href: "#",
          status: {
            text: "Completed"
          }
        },
        {
          title: {
            text: "Scoping consultation documents"
          },
          href: "#",
          status: {
            tag: {
              text: "Incomplete",
              classes: "govuk-tag--blue"
            }
          }
        },
        {
          title: {
            text: "Consultation summary of feedback to scoping consultation"
          },
          hint: {
            text: "Do we need information about each document here?"
          },
          href: "#",
          status: {
            tag: {
              text: "Incomplete",
              classes: "govuk-tag--blue"
            }
          }
        },
        {
          title: {
            text: "Gateway 1 – Self assessment of readiness"
          },
          href: "#",
          status: {
            tag: {
              text: "Incomplete",
              classes: "govuk-tag--blue"
            }
          }
        },
        {
          title: {
            text: "Consultation on proposed local plan content and evidence documents"
          },
          href: "#",
          status: {
            tag: {
              text: "Incomplete",
              classes: "govuk-tag--blue"
            }
          }
        },
        {
          title: {
            text: "Consultation summary for the above"
          },
          href: "#",
          status: {
            tag: {
              text: "Incomplete",
              classes: "govuk-tag--blue"
            }
          }
        }
      ]
    }) }}
   

   
  </div>
  <div class="govuk-tabs__panel govuk-tabs__panel--hidden" id="details">
    <h2 class="govuk-heading-l">Application details</h2>
    <p>Show details of the case which has been entered before the email invitation was sent.</p>
  </div>
  <div class="govuk-tabs__panel govuk-tabs__panel--hidden" id="contacts">
    <h2 class="govuk-heading-l">Contacts</h2>
    <p>This is a placeholder only - there has not been any discussion or decisions about this feature.</p>
    
  </div>
</div>
<p> </p>
<div class="govuk-grid-row "> 
<div class="govuk-grid-column-two-thirds"> 
 <p class="govuk-body">Review the documents you have uploaded and make sure all required sections are complete.</p>

 <p>
  Select <strong>Review and submit application</strong> to check your application before submitting. </p>
<form class="form" action="/projects/front-office/application-review" method="post">    
  {{ govukButton({
    text: "Review and submit application"
  }) }}
</form>
</div>
</div>
</div>  

{% endblock %}

  {% block footer %}
  {% include "includes/footer.njk" %}
{% endblock %}
  
